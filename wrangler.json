{
    "name": "dropsiders",
    "main": "worker.ts",
    "compatibility_date": "2024-09-23",
    "assets": {
        "directory": "./dist",
        "binding": "ASSETS",
        "exclude": [
            "**/.git/**",
            "**/node_modules/**",
            "**/*.map"
        ]
    },
    "observability": {
        "enabled": true
    },
    "routes": [
        {
            "pattern": "dropsiders.fr",
            "custom_domain": true
        },
        {
            "pattern": "www.dropsiders.fr",
            "custom_domain": true
        }
    ],
    "vars": {
        "GITHUB_OWNER": "Itsalexfr1",
        "GITHUB_REPO": "sitedropsiders",
        "GITHUB_FILE_PATH": "src/data/subscribers.json"
    }
}
