    "postcss": "^8.5.6",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "web-push": "^3.6.7",
    "wrangler": "^4.67.0"
