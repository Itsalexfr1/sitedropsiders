    "migrate:r2": "node tools/migrate_to_r2_bulk.cjs",
    "mail:sync": "node tools/mail_bridge.js --watch",
    "mail:once": "node tools/mail_bridge.js"
  },
  "dependencies": {
    "@react-oauth/google": "^0.13.4",
    "@uiw/react-md-editor": "^4.0.11",
    "appwrite": "^23.0.0",
    "axios": "^1.13.5",
    "canvas-confetti": "^1.9.4",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "d3-geo": "^3.1.1",
    "d3-scale": "^4.0.2",
    "framer-motion": "^12.34.0",
    "html2canvas": "^1.4.1",
    "html2pdf.js": "^0.14.0",
    "imap": "^0.8.19",
    "jsdom": "^28.1.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.564.0",
    "mailparser": "^3.9.3",
    "nodemailer": "^8.0.1",
    "qr-code-styling": "^1.9.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-easy-crop": "^5.5.6",
